<Window x:Class="ScreenSubtitleTranslator.ApiKeyConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure OpenAI API Key"
        Width="560"
        Height="430"
        MinWidth="520"
        MinHeight="400"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="OpenAI API Key"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,7,0,0"
                       Text="The key is stored securely in Windows Credential Manager for your Windows account."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Padding="12,10"
                Background="{StaticResource WarningBackgroundBrush}"
                BorderBrush="#F0D7A6"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Text="OpenAI API calls may incur charges. Do not share your API key with anyone."
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource WarningBrush}" />
        </Border>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <TextBlock Text="API KEY"
                       Margin="0,0,0,6"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MutedTextBrush}" />
            <PasswordBox x:Name="ApiKeyPasswordBox"
                         MinHeight="40"
                         Padding="10,7"
                         VerticalContentAlignment="Center"
                         PasswordChar="●" />
            <TextBlock x:Name="KeySourceText"
                       Margin="0,7,0,0"
                       FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}" />
        </StackPanel>

        <Border x:Name="StatusBorder"
                Grid.Row="3"
                Margin="0,16,0,0"
                Padding="12,9"
                Background="{StaticResource PanelAltBrush}"
                CornerRadius="6">
            <TextBlock x:Name="StatusText"
                       Text="Enter a key, then save it or test the connection."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}" />
        </Border>

        <Grid Grid.Row="5" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="ClearButton"
                    Grid.Column="0"
                    Content="Clear Key"
                    Click="OnClearClicked" />
            <Button x:Name="TestButton"
                    Grid.Column="2"
                    Margin="0,0,10,0"
                    Content="Test API Key"
                    Click="OnTestClicked" />
            <Button Grid.Column="3"
                    Margin="0,0,10,0"
                    Content="Cancel"
                    IsCancel="True" />
            <Button x:Name="SaveButton"
                    Grid.Column="4"
                    Content="Save"
                    IsDefault="True"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnSaveClicked" />
        </Grid>
    </Grid>
</Window>
