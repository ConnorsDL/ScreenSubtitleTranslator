<Window x:Class="ScreenSubtitleTranslator.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Subtitle Overlay"
        Width="960"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        Background="Transparent"
        Focusable="False"
        FontFamily="Segoe UI, Microsoft YaHei UI">
    <Border x:Name="RootBorder"
            Margin="12"
            Padding="24,16"
            Background="#DC171B21"
            BorderBrush="#38FFFFFF"
            BorderThickness="1"
            CornerRadius="8"
            IsHitTestVisible="False">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              Direction="270"
                              ShadowDepth="3"
                              Color="#000000"
                              Opacity="0.32" />
        </Border.Effect>
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="OriginalTextBlock"
                       Margin="0,0,0,7"
                       Text=""
                       Foreground="#D6FFFFFF"
                       FontSize="19"
                       LineHeight="26"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Visibility="Collapsed" />
            <TextBlock x:Name="TranslatedTextBlock"
                       Text=""
                       Foreground="#FFFFFFFF"
                       FontSize="30"
                       FontWeight="SemiBold"
                       LineHeight="40"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
