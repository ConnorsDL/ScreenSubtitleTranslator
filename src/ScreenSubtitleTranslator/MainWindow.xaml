<Window x:Class="ScreenSubtitleTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Subtitle Translator"
        Width="1120"
        Height="760"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>

        <Style x:Key="SettingsGridStyle" TargetType="{x:Type Grid}">
            <Setter Property="IsEnabled" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.62" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModuleItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="28,20"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Screen Subtitle Translator"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding SelectedSettingsSummary}"
                               Margin="0,5,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="20,0,24,0"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Padding="10,6"
                                Background="{StaticResource PanelAltBrush}"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,7,0">
                                    <Ellipse.Style>
                                        <Style TargetType="{x:Type Ellipse}">
                                            <Setter Property="Fill" Value="#98A2B3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WindowStatus}" Value="Running">
                                                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding WindowStatus}" Value="Error">
                                                    <Setter Property="Fill" Value="{StaticResource ErrorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding WindowStatus}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Margin="10,0,0,0"
                                Padding="10,6"
                                CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Background" Value="{StaticResource SuccessBackgroundBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsApiKeyConfigured}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ApiKeyStatus}" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsApiKeyConfigured}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,6,0,0"
                               MaxWidth="390"
                               TextAlignment="Right"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Start"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding StartCommand}" />
                    <Button Content="Stop"
                            Margin="10,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding StopCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="28,14,28,0"
                Padding="14,10"
                Background="{StaticResource ErrorBackgroundBrush}"
                BorderBrush="#F4C7C3"
                BorderThickness="1"
                CornerRadius="6">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ErrorBrush}" />
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,18,28,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Audio Device" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="WASAPI loopback" Style="{StaticResource SectionSubtitleStyle}" />

                        <TextBlock Text="CURRENT CAPTURE DEVICE"
                                   Margin="0,20,0,6"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <Border Padding="12"
                                Background="{StaticResource PanelAltBrush}"
                                CornerRadius="6">
                            <TextBlock Text="{Binding CurrentCaptureDeviceName}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="12,10"
                                Background="{StaticResource WarningBackgroundBrush}"
                                BorderBrush="#F0D7A6"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DeviceAlertMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding DeviceAlertMessage}"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource WarningBrush}" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Languages" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Recognition and translation" Style="{StaticResource SectionSubtitleStyle}" />

                        <Grid Margin="0,20,0,0" Style="{StaticResource SettingsGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SOURCE LANGUAGE" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding SourceLanguages}"
                                          SelectedItem="{Binding SourceLanguage}"
                                          DisplayMemberPath="DisplayName" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TARGET LANGUAGE" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding TargetLanguages}"
                                          SelectedItem="{Binding TargetLanguage}"
                                          DisplayMemberPath="DisplayName" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="0"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Subtitle Settings" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Display and latency" Style="{StaticResource SectionSubtitleStyle}" />

                        <Grid Margin="0,20,0,0" Style="{StaticResource SettingsGridStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="SUBTITLE MODE" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding SubtitleModes}"
                                          SelectedItem="{Binding SubtitleMode}"
                                          DisplayMemberPath="DisplayName" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="LATENCY MODE" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding LatencyModes}"
                                          SelectedValue="{Binding AudioChunkSeconds}"
                                          SelectedValuePath="Seconds"
                                          DisplayMemberPath="DisplayName" />
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Margin="0,16,0,0"
                                        Orientation="Horizontal">
                                <Button Content="Save settings"
                                        Command="{Binding SaveSettingsCommand}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Runtime Status" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Style="{StaticResource SectionSubtitleStyle}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,14,0,12"
                                Padding="12,8"
                                Background="{StaticResource PanelAltBrush}"
                                CornerRadius="6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding AppStatus}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentDarkBrush}" />
                                <TextBlock Text="Current stage"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </DockPanel>
                        </Border>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding PipelineModules}"
                                 ItemContainerStyle="{StaticResource ModuleItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1"
                                                Margin="0,0,10,0"
                                                Padding="7,3"
                                                Background="{StaticResource PanelAltBrush}"
                                                CornerRadius="5">
                                            <TextBlock Text="{Binding State}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Stretch"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource AccentDarkBrush}" />
                                        </Border>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Details}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <Expander Grid.Row="3"
                  Margin="28,0,28,18"
                  IsExpanded="False"
                  Background="{StaticResource PanelBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1">
            <Expander.Header>
                <TextBlock Text="Recent events"
                           Padding="10,8"
                           FontWeight="SemiBold" />
            </Expander.Header>
            <ListBox ItemsSource="{Binding RecentLogs}"
                     MaxHeight="140"
                     Margin="12,0,12,12"
                     FontFamily="Consolas, Microsoft YaHei UI"
                     FontSize="12" />
        </Expander>
    </Grid>
</Window>
